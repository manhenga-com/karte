# Local development can use SQLite by leaving DB_ENGINE empty or setting sqlite.
DB_ENGINE=sqlite

# For MySQL, set DB_ENGINE=mysql and fill these values.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=mikrotik_vouchers
MYSQL_USER=voucher_app
MYSQL_PASSWORD=change-this-password

ENABLE_BACKGROUND_SYNC=1
BACKGROUND_SYNC_SECONDS=300

# Set this to a long random value on a VPS so browser sessions survive restarts.
SECRET_KEY=change-this-to-a-long-random-secret

